# Copy to .env and fill in values. Never commit real secrets.

OPENAI_API_KEY=

# Async SQLAlchemy URL (asyncpg). Matches docker-compose defaults:
DATABASE_URL=postgresql+asyncpg://app:app@127.0.0.1:5432/app

# Chroma persistent directory (created automatically)
CHROMA_PATH=./.chroma_data
CHROMA_COLLECTION=schema_docs

# Optional: comma-separated browser origins if you call the API from a web app.
# Leave unset or empty for Postman / curl / same-origin Swagger only.
# CORS_ORIGINS=http://127.0.0.1:3000

OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

CHAT_HISTORY_LIMIT=30
SCHEMA_RETRIEVAL_K=5
AGENT_MAX_TOOL_ROUNDS=8

# Set to false to hide debug block in /api/chat responses
INCLUDE_DEBUG_IN_RESPONSE=true
